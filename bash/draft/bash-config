# $SHELL -> seu shell atual
# $PWD -> seu diretorio atual
# $OLDPWD -> seu diretorio anterior 
# $HOSTNAME -> seu hostname
# $LANG -> seu idioma
# $PATH -> seu path
# $$ -> numero do processo do shell
# $? -> codigo de saida
# $# -> quantidade de parametros do script
