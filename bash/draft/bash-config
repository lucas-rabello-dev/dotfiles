# configuring the bash prompt PS1 = Prompt String 1

# PS1 → prompt principal
# PS2 → prompt de continuação de um comando (>)
# PS3 → usado em menus
# PS4 → debug (set -x)


PS1="da o comando ai: "

# ==== exemplo de informações ======

# \u -> usuario
# \h -> hostname
# \w -> diretorio atual (nome do caminho completo)
# \W -> So o nome da pasta atual (sem o caminho completo)
# \$ -> $ ou # ($ para o modo normal e # para root)
# \A -> mostra as horas
# \t -> mostra as horas com segundos
# \d -> mostra a data
# \! -> numero do comando no historico
# \# -> numero de quantos comando voce deu na sessao atual

# cores ======== 

# \[\e[30m\] -> preto
# \[\e[31m\] -> vermelho
# \[\e[32m\] -> verde
# \[\e[33m\] -> amarelo
# \[\e[34m\] -> azul
# \[\e[35m\] -> magenta
# \[\e[36m\] -> ciano
# \[\e[37m\] -> branco
# \[\e[0m\] -> reseta a cor, tipo vc define vermelho um lugar e dps vc 'fecha'

# cores brilhantes ==============
# \[\e[1;31m\] -> vermelho forte, deixa bold


